# ── LLM Provider ──────────────────────────────────────────────────────────────
# NVIDIA NIM (default) — get key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=mistralai/mixtral-8x7b-instruct

# (Optional) Fall-through providers — used only if NVIDIA_API_KEY is not set
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# ── Observability ──────────────────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=project8-deep-agents
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL (matches docker-compose.yml: user project8, db HelpingHireRecruiter)
DATABASE_URL=postgresql+asyncpg://project8:project8@127.0.0.1:5432/HelpingHireRecruiter
